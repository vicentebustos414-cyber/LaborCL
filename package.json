{
  "name": "laborcl",
  "version": "1.0.0",
  "description": "Calculadoras y guías de Derecho Laboral Chileno",
  "main": "electron-main.js",
  "author": "LaborCL",
  "license": "MIT",
  "scripts": {
    "dev": "vite --config vite.config.ts",
    "build:react": "vite build --config vite.config.ts",
    "preview": "vite preview --config vite.config.ts",
    "start": "electron .",
    "build-portable": "npm run build:react && cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --win portable --x64 --config.win.signAndEditExecutable=false",
    "build-win": "npm run build:react && electron-builder --win --x64",
    "icons": "node make-icons.js",
    "serve": "node server.js"
  },
  "dependencies": {
    "@capacitor/android": "^8.4.0",
    "@capacitor/cli": "^8.4.0",
    "@capacitor/core": "^8.4.0",
    "@paper-design/shaders-react": "^0.0.76",
    "@tailwindcss/vite": "^4.3.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "electron-updater": "^6.1.0",
    "express": "^5.2.1",
    "framer-motion": "^12.40.0",
    "lucide-react": "^1.17.0",
    "multer": "^1.4.5-lts.1",
    "pdfjs-dist": "^4.0.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.17.0",
    "tailwind-merge": "^3.6.0",
    "tesseract.js": "^5.0.4"
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "autoprefixer": "^10.5.0",
    "cross-env": "^7.0.3",
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0",
    "postcss": "^8.5.15",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.16"
  },
  "build": {
    "appId": "cl.laborcl.app",
    "productName": "LaborCL",
    "copyright": "Copyright © 2024 LaborCL",
    "directories": {
      "output": "electron-dist"
    },
    "files": [
      "index.html",
      "electron-main.js",
      "update-checker.js",
      "version.json",
      "icons/**",
      "!icons/*.svg",
      "!node_modules/sharp/**",
      "!make-icons.js",
      "!generate-icons.js"
    ],
    "portable": {
      "artifactName": "LaborCL-Portable-${version}.exe"
    },
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "icons/icon.ico"
    },
    "publish": {
      "provider": "github",
      "owner": "laborcl",
      "repo": "laborcl-app"
    }
  }
}
